  <credit page="1">
    <credit-type>title</credit-type>
    <credit-words default-x="616" default-y="1573" font-size="24" justify="center" valign="top">Achtel Grooves 1.1
</credit-words>
  </credit>
  <credit page="1">
    <credit-type>rights</credit-type>
    <credit-words default-x="616" default-y="53" font-size="10" justify="center" valign="bottom">© Bernhard Henke info@bergcussion.com
</credit-words>
  </credit>
  <credit page="1">
    <credit-words default-x="138" default-y="502" font-size="12" valign="top">- Übe die Grooves links wie rechts. Übe jeden Groove mindestens 1 minute lang.
- Die HiHat und Snare sind immer gleich.
- nur die Basedrum verändert sich.
- Übe langsam,
- gerne auch mit Metronom
</credit-words>
  </credit>
